#!/bin/bash
BACKUP_DIR="{{ backups_dir }}/etcd"
mkdir -p "$BACKUP_DIR"

TIMESTAMP=$(date '+%Y-%m-%d_%H-%M-%S')
BACKUP_FILE="$BACKUP_DIR/etcd_$TIMESTAMP.db"

echo "Saving etcd snapshot to $BACKUP_FILE..."
time ETCDCTL_API=3 etcdctl --endpoints=http://"{{ etcd.host }}":"{{ etcd.port }}" snapshot save "$BACKUP_FILE"

echo "Snapshot saved. Current files in $BACKUP_DIR:"
ls -lh "$BACKUP_DIR"